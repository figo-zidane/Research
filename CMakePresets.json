{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 26,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/.vcpkg/scripts/buildsystems/vcpkg.cmake"
      },
      "environment": {
        "VCPKG_ROOT": "${sourceDir}/.vcpkg",
        "VCPKG_DISABLE_METRICS": "1",
        "VCPKG_FEATURE_FLAGS": "manifests,versions",
        "VCPKG_BINARY_SOURCES": "clear;files,${sourceDir}/build/vcpkg-binary-cache,readwrite",
        "VCPKG_DOWNLOADS": "${sourceDir}/build/vcpkg-asset-cache"
      }
    },
    {
      "name": "base-ninja",
      "hidden": true,
      "inherits": "base",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "base-vs2026",
      "hidden": true,
      "inherits": "base",
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "binaryDir": "${sourceDir}/build/vs2026"
    },
    {
      "name": "windows-msvc-x64-debug",
      "inherits": "base-ninja",
      "displayName": "Windows MSVC x64 Debug (Ninja)",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-msvc-x64-release",
      "inherits": "base-ninja",
      "displayName": "Windows MSVC x64 Release (Ninja)",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "vs2026-x64",
      "inherits": "base-vs2026",
      "displayName": "Visual Studio 2026 x64 (Debug/Release)",
      "description": "Multi-config VS generator. Use --config Debug or Release at build time."
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "configurePreset": "windows-msvc-x64-debug"
    },
    {
      "name": "build-release",
      "configurePreset": "windows-msvc-x64-release"
    },
    {
      "name": "vs2026-debug",
      "configurePreset": "vs2026-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs2026-release",
      "configurePreset": "vs2026-x64",
      "configuration": "Release"
    }
  ]
}
